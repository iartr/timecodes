# AssemblyAI — https://www.assemblyai.com/app/api-keys
ASSEMBLYAI_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
OPENAI_SYSTEM_PROMPT="Ты редактор YouTube. На основе расшифровки сгенерируй от 5 до 15 таймкодов глав видео. Первая глава должна быть в 00:00. Каждая глава — краткое (2-6 слов), информативное название. Без нумерации, без вступлений и заключений. Используй формат HH:MM:SS только если видео длиннее часа, иначе MM:SS."

# Необязательно — путь к yt-dlp, если не в PATH
YTDLP_PATH=

# --- yt-dlp cookies (для YouTube, который требует авторизации) ---
#
# Работают только локально: --cookies-from-browser читает cookies из установленного
# браузера на ТОЙ ЖЕ машине, где запущен yt-dlp. На Railway (Docker) браузера нет,
# поэтому YTDLP_COOKIES_FROM_BROWSER не сработает — используйте один из двух
# вариантов ниже.
#
# Вариант 1: локальная разработка — "chrome", "firefox", "safari", "edge", "brave".
# Yandex Browser не поддерживается напрямую, но его профиль совместим с Chromium —
# проще всего экспортировать cookies.txt расширением и использовать вариант 2/3.
YTDLP_COOKIES_FROM_BROWSER=
#
# Вариант 2: путь к файлу cookies.txt (Netscape format).
# Задайте, если файл смонтирован в контейнер (например, через Railway Volume).
YTDLP_COOKIES_FILE=
#
# Вариант 3 (рекомендовано для Railway): содержимое cookies.txt прямо в env-переменной.
# Экспортируйте cookies из браузера расширением "Get cookies.txt LOCALLY" (или аналогом),
# откройте файл, скопируйте ВСЁ содержимое сюда. Мы запишем его во временный файл
# на время задачи и удалим после завершения.
YTDLP_COOKIES_CONTENT=
#
# Дополнительные аргументы для yt-dlp (через пробел, поддерживает кавычки).
# Пример: --extractor-args "youtube:player_client=android" --force-ipv4
YTDLP_EXTRA_ARGS=

# Необязательно — путь к ffmpeg, если не в PATH
FFMPEG_PATH=

# Максимальный размер загружаемого файла в мегабайтах (default: 2048)
MAX_UPLOAD_MB=2048

# Уровень логирования: debug | info | warn | error (default: info).
# На Railway при отладке поставьте debug — будут видны все строки stdout/stderr yt-dlp и ffmpeg.
LOG_LEVEL=info

# Порт (для Railway: устанавливается автоматически)
PORT=3000
